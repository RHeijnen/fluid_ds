{
  "name": "@fluid-ds/qr",
  "version": "0.0.1-alpha.0",
  "description": "Themable QR code web component for Fluid (expansion pack), rendered as crisp inline SVG. Backed by qrcode-generator.",
  "type": "module",
  "license": "MIT",
  "author": "Fluid contributors",
  "homepage": "https://github.com/RHeijnen/fluid_ds",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RHeijnen/fluid_ds.git",
    "directory": "packages/qr"
  },
  "bugs": {
    "url": "https://github.com/RHeijnen/fluid_ds/issues"
  },
  "keywords": [
    "fluid-ds",
    "qr-code",
    "svg",
    "web-components",
    "design-system"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "alpha",
    "provenance": true,
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./define": {
        "types": "./dist/define.d.ts",
        "import": "./dist/define.js"
      }
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./define": {
      "types": "./src/define.ts",
      "import": "./src/define.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "**/define.js",
    "**/define.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "lit": "^3.2.1",
    "qrcode-generator": "^1.4.4"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
