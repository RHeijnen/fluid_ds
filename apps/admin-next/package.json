{
  "name": "@fluid-ds/admin-next",
  "version": "0.0.1",
  "private": true,
  "description": "Admin-portal demo built with Next.js (App Router) + the Fluid web components, showing the SSR-safe client registration pattern.",
  "scripts": {
    "predev": "pnpm --filter @fluid-ds/tokens build",
    "dev": "next dev -p 5291",
    "build": "next build",
    "start": "next start -p 5291",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fluid-ds/charts": "workspace:*",
    "@fluid-ds/components": "workspace:*",
    "@fluid-ds/icons": "workspace:*",
    "@fluid-ds/themes": "workspace:*",
    "@fluid-ds/tokens": "workspace:*",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.2"
  }
}
