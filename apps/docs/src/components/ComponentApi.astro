---
/**
 * Renders the API reference tables for one fluid-* tag.
 *
 * Default source is the Custom Elements Manifest (CEM) generated by
 * `cem analyze` in `packages/components`. Editorial overrides can be
 * passed for any section if a page wants to customize the rendering or
 * augment auto-generated data.
 *
 * Usage in MDX:
 *
 * ```mdx
 * import ComponentApi from "../../components/ComponentApi.astro";
 *
 * <ComponentApi tag="fluid-button" />
 *
 * // With overrides for the events table only:
 * <ComponentApi tag="fluid-button" events={[
 *   { name: "fluid-click", description: "Custom description." }
 * ]} />
 * ```
 */
import {
  declarationFor,
  attributes as cemAttributes,
  events as cemEvents,
  slots as cemSlots,
  cssParts as cemCssParts,
  cssProperties as cemCssProperties,
  usesTokens as cemUsesTokens,
  type CemMember,
  type CemEvent,
  type CemSlot,
  type CemCssPart,
  type CemCssProperty,
  type CemUsesToken
} from "../lib/cem";

interface Props {
  /** Custom-element tag name (e.g. "fluid-button"). */
  tag: string;
  /** Optional override of the attributes/props table. */
  attributes?: CemMember[];
  /** Optional override of the events table. */
  events?: CemEvent[];
  /** Optional override of the slots table. */
  slots?: CemSlot[];
  /** Optional override of the CSS parts table. */
  cssParts?: CemCssPart[];
  /** Optional override of the CSS custom properties table. */
  cssProperties?: CemCssProperty[];
  /** Optional override of the semantic tokens the component reads. */
  usesTokens?: CemUsesToken[];
  /** Show or hide section headers (default true). */
  showHeadings?: boolean;
}

const props = Astro.props;
const tag = props.tag;
const decl = declarationFor(tag);

const data = {
  attributes: props.attributes ?? cemAttributes(decl),
  events: props.events ?? cemEvents(decl),
  slots: props.slots ?? cemSlots(decl),
  cssParts: props.cssParts ?? cemCssParts(decl),
  cssProperties: props.cssProperties ?? cemCssProperties(decl),
  usesTokens: props.usesTokens ?? cemUsesTokens(decl)
};

const showHeadings = props.showHeadings !== false;

// Render description for the default slot ("" name) without quoting it.
function slotLabel(name: string | undefined): string {
  return name && name.length ? name : "(default)";
}
---

{!decl && (
  <p class="fluid-api-empty">
    No CEM entry for <code>{tag}</code>. Check the tag spelling or rebuild the
    manifest with <code>pnpm --filter @fluid-ds/components analyze</code>.
  </p>
)}

{data.attributes.length > 0 && (
  <section>
    {showHeadings && <h3 id="properties">Properties &amp; attributes</h3>}
    <table class="fluid-api-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Attribute</th>
          <th>Type</th>
          <th>Default</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        {data.attributes.map((m) => (
          <tr>
            <td><code>{m.name}</code></td>
            <td>{m.attribute ? <code>{m.attribute}</code> : <span>–</span>}</td>
            <td>{m.type?.text ? <code>{m.type.text}</code> : <span>–</span>}</td>
            <td>{m.default ? <code>{m.default}</code> : <span>–</span>}</td>
            <td>{m.description ?? ""}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
)}

{data.events.length > 0 && (
  <section>
    {showHeadings && <h3 id="events">Events</h3>}
    <table class="fluid-api-table">
      <thead>
        <tr><th>Name</th><th>Detail</th><th>Description</th></tr>
      </thead>
      <tbody>
        {data.events.map((e) => (
          <tr>
            <td><code>{e.name}</code></td>
            <td>{e.type?.text ? <code>{e.type.text}</code> : <span>–</span>}</td>
            <td>{e.description ?? ""}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
)}

{data.slots.length > 0 && (
  <section>
    {showHeadings && <h3 id="slots">Slots</h3>}
    <table class="fluid-api-table">
      <thead><tr><th>Name</th><th>Description</th></tr></thead>
      <tbody>
        {data.slots.map((s) => (
          <tr>
            <td><code>{slotLabel(s.name)}</code></td>
            <td>{s.description ?? ""}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
)}

{data.cssParts.length > 0 && (
  <section>
    {showHeadings && <h3 id="css-parts">CSS parts</h3>}
    <table class="fluid-api-table">
      <thead><tr><th>Part</th><th>Description</th></tr></thead>
      <tbody>
        {data.cssParts.map((p) => (
          <tr>
            <td><code>{p.name}</code></td>
            <td>{p.description ?? ""}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
)}

{data.cssProperties.length > 0 && (
  <section>
    {showHeadings && <h3 id="css-custom-properties">CSS custom properties</h3>}
    <table class="fluid-api-table">
      <thead><tr><th>Name</th><th>Description</th></tr></thead>
      <tbody>
        {data.cssProperties.map((p) => (
          <tr>
            <td><code>{p.name}</code></td>
            <td>{p.description ?? ""}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
)}

{data.usesTokens.length > 0 && (
  <section>
    {showHeadings && <h3 id="semantic-tokens">Semantic tokens consumed</h3>}
    <table class="fluid-api-table">
      <thead><tr><th>Token</th><th>Used for</th></tr></thead>
      <tbody>
        {data.usesTokens.map((t) => (
          <tr>
            <td><code>{t.name}</code></td>
            <td>{t.description ?? ""}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
)}
