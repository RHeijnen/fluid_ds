---
/*
 * Override of Starlight's default <Head>, wrapping it so we can inject a
 * single shared script that registers every Fluid web component and the
 * default icon set.
 *
 * Critical: we must explicitly forward Astro.props to the inner default.
 * Starlight passes page-context (entry, locale, headings, sidebar etc.)
 * through that prop bag; if we drop it, internal route generation
 * (notably the static /404 route) destructures an undefined value and the
 * build fails. We type the spread via Starlight's exported Props alias so
 * `astro check` doesn't lose track of the bag's shape.
 *
 * The inline <script> block is processed by Astro: imports get bundled
 * into a real module that's emitted once per page, code-split + cached.
 */
import Default from "@astrojs/starlight/components/Head.astro";
import type { Props } from "@astrojs/starlight/props";

const props = Astro.props as Props;
---

<Default {...props}><slot /></Default>

{/*
  FOUC-safe sync of Starlight's light/dark toggle into the Fluid
  token system. Starlight writes `data-theme="light|dark"` on <html>;
  our @fluid-ds/tokens/dark.css gates on `[data-fluid-theme="dark"]`.
  Without this mirror, toggling Starlight's button repainted the
  Starlight chrome but every embedded <fluid-*> component stayed in
  light mode regardless.

  Also restores the persisted brand preset (default / midnight /
  corporate) before paint so the first frame matches the user's
  last choice rather than flashing through the default brand.

  Inline + early so it runs before first paint, avoiding a visible
  light→dark or default→midnight flicker on load.
*/}
<script is:inline>
  (() => {
    const html = document.documentElement;
    const sync = () => {
      const t = html.dataset.theme === "dark" ? "dark" : "light";
      if (html.dataset.fluidTheme !== t) html.dataset.fluidTheme = t;
    };
    sync();
    new MutationObserver(sync).observe(html, {
      attributes: true,
      attributeFilter: ["data-theme"]
    });
    try {
      const brand = localStorage.getItem("fluid-docs-brand");
      if (brand && brand !== "default") html.dataset.fluidBrand = brand;
    } catch {
      /* localStorage may throw in private modes, ignore */
    }
    try {
      // Restore the AA/AAA conformance choice before paint so the header
      // toggle + every live example match the user's last choice with no flash.
      if (localStorage.getItem("fluid-docs-conformance") === "aaa") {
        html.dataset.fluidConformance = "aaa";
      }
    } catch {
      /* localStorage may throw in private modes, ignore */
    }
  })();
</script>

