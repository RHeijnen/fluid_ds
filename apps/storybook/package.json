{
  "name": "@fluid-ds/storybook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @fluid-ds/tokens build",
    "dev": "storybook dev -p 6006 --no-open --disable-telemetry",
    "predev:open": "pnpm --filter @fluid-ds/tokens build",
    "dev:open": "storybook dev -p 6006 --disable-telemetry",
    "prebuild": "pnpm --filter @fluid-ds/tokens build",
    "build": "storybook build --disable-telemetry",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fluid-ds/animations": "workspace:*",
    "@fluid-ds/components": "workspace:*",
    "@fluid-ds/icons": "workspace:*",
    "@fluid-ds/themes": "workspace:*",
    "@fluid-ds/tokens": "workspace:*",
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@etchteam/storybook-addon-status": "^5.0.0",
    "@storybook/addon-a11y": "^8.4.7",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-interactions": "^8.4.7",
    "@storybook/addon-themes": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/web-components": "^8.4.7",
    "@storybook/web-components-vite": "^8.4.7",
    "@whitespace/storybook-addon-html": "^6.1.1",
    "prettier": "^3.4.2",
    "storybook": "^8.4.7",
    "storybook-addon-pseudo-states": "^4.0.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
